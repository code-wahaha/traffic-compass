# ===== 流量罗盘 · 环境变量示例 =====
# 用法：复制本文件为 .env 并填入你的 key，或直接在系统环境 / 部署平台里配置。
# （也可改用 webapp/_data/apikeys.json，见 apikeys.example.json）

# DeepSeek（必填）—— 文案审核与流量评分的核心大脑
DEEPSEEK_KEY=在此填入你的DeepSeek密钥
DEEPSEEK_MODEL=deepseek-v4-flash      # 快且省；deepseek-v4-pro 为思考模式，更准更慢

# 百炼 / 阿里云 DashScope（可选）—— 链接提取的语音转写 ASR
BAILIAN_KEY=在此填入你的百炼密钥（可选）

# 关闭"链接提取"（没有抖音 cookie 时建议设为 1，只用文字粘贴模式）
DISABLE_EXTRACT=1

# 抖音 cookie 基目录（可选，链接提取用；其下需有 chrome_data/douyin_cookies.json）
# DOUYIN_COOKIE_BASE=
